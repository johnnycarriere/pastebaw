generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Paste {
  id         String    @id @default(cuid())
  content    String
  language   String    @default("plaintext")
  title      String?
  description String?
  createdAt  DateTime  @default(now()) @map("created_at")
  expiresAt  DateTime? @map("expires_at")
  isCompressed Boolean @default(false) @map("is_compressed")
  passwordHash String?  @map("password_hash")
  views      Int       @default(0)
  burnAfterRead Boolean @default(false) @map("burn_after_read")
  aiGenerationStatus String? @default("PENDING") @map("ai_generation_status")
  
  // Image support
  hasImage   Boolean   @default(false) @map("has_image")
  imageKey   String?   @map("image_key")
  imageUrl   String?   @map("image_url")
  imageMimeType String? @map("image_mime_type")
  imageSize  Int?      @map("image_size")
  imageWidth Int?      @map("image_width")
  imageHeight Int?     @map("image_height")
  originalFormat String? @map("original_format")
  originalMimeType String? @map("original_mime_type")
  exifData   Json?    @map("exif_data")
  pasteType  String    @default("text") @map("paste_type")

  // File upload support
  fileKey    String?   @map("file_key")
  fileUrl    String?   @map("file_url")
  fileName   String?   @map("file_name")
  fileSize   BigInt?   @map("file_size")
  fileMimeType String? @map("file_mime_type")

  @@map("pastes")
  @@index([language])
  @@index([createdAt])
  @@index([expiresAt])
}
